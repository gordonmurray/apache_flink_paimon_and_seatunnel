# Local demo settings for the Compose stack.
# These are throwaway credentials for a local MinIO instance, not real AWS keys.

# MinIO root credentials. Also used as the S3 access key / secret key by Flink and Paimon.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# S3 endpoint and buckets. Paimon holds the Flink CDC output; Iceberg holds the
# table SeaTunnel writes after transforming the Paimon data.
S3_ENDPOINT=http://minio:9000
PAIMON_BUCKET=paimon
ICEBERG_BUCKET=iceberg
