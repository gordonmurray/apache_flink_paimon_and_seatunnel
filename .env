# Local demo settings for the Compose stack.
# These are throwaway credentials for a local SeaweedFS instance, not real AWS keys.

# Component versions used by Compose and the SeaTunnel image build.
FLINK_VERSION=1.20.4-java11
SEATUNNEL_VERSION=2.3.13

# S3 credentials for the local SeaweedFS instance. Also used as the S3 access key / secret key by Flink and Paimon.
S3_ACCESS_KEY=admin
S3_SECRET_KEY=adminsecret

# S3 endpoint and buckets. Paimon holds the Flink CDC output; Iceberg holds the
# table SeaTunnel writes after transforming the Paimon data.
S3_ENDPOINT=http://seaweedfs:9000
PAIMON_BUCKET=paimon
ICEBERG_BUCKET=iceberg
